rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() { return request.auth != null; }
    function uid() { return request.auth.uid; }

    // Safe role check — reads the user document
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid()));
    }
    function role() {
      return isAuth() && exists(/databases/$(database)/documents/users/$(uid()))
        ? userDoc().data.role
        : 'guest';
    }
    function isAdmin() { return isAuth() && role() == 'admin'; }
    // All authenticated users with a profile are considered "researchers" for read/write on lab data
    function isUser() { return isAuth() && (role() == 'admin' || role() == 'usuario' || role() == 'researcher' || role() == 'estudiante' || role() == 'profesor_asignado'); }

    // Users
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && uid() == userId;
      allow update: if isAuth() && (uid() == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Invitations (registration flow)
    match /invitations/{inviteId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Legacy invites collection
    match /invites/{inviteId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Reservations
    match /reservations/{resId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.userId == uid() || isAdmin());
      allow delete: if isAdmin();
    }

    // Equipment
    match /equipment/{equipId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Inventory — all authenticated users can read; admins can fully manage
    match /inventory/{itemId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Inventory movements — all authenticated users can log movements and read
    match /inventory_movements/{movId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // Audit logs — all authenticated users can create; only admins and users can read
    match /audit_log/{logId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // Damage reports
    match /damage_reports/{repId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Emergency alerts
    match /emergencyAlerts/{alertId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
    }

    // Lab settings
    match /lab_settings/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
